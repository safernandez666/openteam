{
  "name": "openteam-web",
  "version": "0.3.2",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "dist/public"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsup && mkdir -p dist/public && cp -r ../ui/dist/* dist/public/ 2>/dev/null || true",
    "dev": "tsx watch src/server.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "openteam-core": "workspace:*",
    "express": "^5.1.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "supertest": "^7.2.2",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3"
  }
}

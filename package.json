{
  "name": "openteam",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "AI agent orchestration framework — spawn a team of AI agents that collaborate to build your project",
  "author": "Santiago Fernandez",
  "license": "MIT",
  "homepage": "https://github.com/safernandez666/openteam",
  "repository": {
    "type": "git",
    "url": "https://github.com/safernandez666/openteam"
  },
  "bugs": "https://github.com/safernandez666/openteam/issues",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "start": "node packages/cli/dist/index.js start",
    "dev": "pnpm -r --parallel run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'packages/*/src/**/*.{ts,tsx}'",
    "clean": "pnpm -r run clean",
    "publish:all": "pnpm build && pnpm -r publish --access public --no-git-checks",
    "demo:spawn": "tsx packages/core/src/demo-spawn.ts",
    "demo:mcp": "tsx packages/core/src/demo-mcp.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "node-pty",
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.25.0",
    "jsdom": "^29.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.0",
    "vitest": "^3.1.0"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0"
  }
}
